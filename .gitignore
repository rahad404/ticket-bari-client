# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage
/.nyc_output
.playwright/
/test-results/

# Next.js build outputs
/.next/
/out/

# Misc & Security
.DS_Store
*.pem
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Strict Environment Files (CRITICAL: Never commit raw secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Vercel deployments
.vercel

# IDEs, Editors, and System Configurations
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Monorepo Caching
.turbo/
